#include <stdio.h>

int main() {
    int num, original, digit1, digit2, digit3, sum = 0;
    
    printf("Enter a three-digit number: ");
    scanf("%d", &num);
    original = num;
    
    // Extract units digit
    digit1 = num % 10;
    num /= 10;
    
    // Extract tens digit
    digit2 = num % 10;
    num /= 10;
    
    // Extract hundreds digit
    digit3 = num;
    
    // Calculate sum of cubes
    sum = digit1*digit1*digit1 + digit2*digit2*digit2 + digit3*digit3*digit3;
    
    // Check and print result
    if (sum == original) {
        printf("%d is an Armstrong number.
", original);
    } else {
        printf("%d is not an Armstrong number.
", original);
    }
    
    return 0;
}
